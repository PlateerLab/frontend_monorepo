# Backend API URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_URL=http://localhost:8000
NEXT_PUBLIC_SSO_URL=http://localhost:8000/sso

NEXT_PUBLIC_THEME=old-xgen

# Teams Mock Mode (방/메시지는 mock, 에이전트는 실제 xgen API)
NEXT_PUBLIC_TEAMS_MOCK=true
NEXT_PUBLIC_TEAMS_REAL_AGENTS=true
NEXT_PUBLIC_ADMIN_MODE=true
