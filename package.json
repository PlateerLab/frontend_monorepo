{
  "name": "xgen-frontend-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @xgen/web dev",
    "dev:web": "pnpm --filter @xgen/web dev",
    "build": "pnpm --filter @xgen/web build",
    "build:web": "pnpm --filter @xgen/web build",
    "start": "pnpm --filter @xgen/web start",
    "start:web": "pnpm --filter @xgen/web start",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf node_modules dist .next"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
