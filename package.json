{
  "name": "xgen-frontend-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@xgen/web",
    "dev:web-jeju": "turbo dev --filter=@xgen/web-jeju",
